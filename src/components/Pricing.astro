---
// App-source references:
// https://github.com/monkeyboiii/Pinmoji/blob/main/iOS/Pinmoji/Views/PaywallView.swift
// https://github.com/monkeyboiii/Pinmoji/blob/main/iOS/Pinmoji/Models/SubscriptionTier.swift
const tiers = [
  {
    name: 'Free',
    price: '$0',
    badge: '',
    tagline: 'Always free',
    features: [
      'Post emoji statuses',
      'Like & discover nearby',
      'Leaderboard access',
      'Basic badges',
      '3 chats · 50 messages each',
      '80-day status history',
    ],
    highlighted: false,
  },
  {
    name: 'Bronze',
    price: '$0.99',
    originalPrice: '$1.99',
    badge: '🥉',
    tagline: 'Get started',
    features: [
      'Full emoji library + skin tones',
      'Pinmoji flair on the map',
      '10 chats · 200 messages each',
      'Status expiry rounds to the half-hour',
      '200-day history',
    ],
    highlighted: false,
  },
  {
    name: 'Silver',
    price: '$1.99',
    originalPrice: '$3.99',
    badge: '🥈',
    tagline: 'Most popular',
    features: [
      'Everything in Bronze',
      'Calendar export — no watermark',
      '25 chats · 500 messages each',
      'Status expiry rounds to the hour',
      '385-day history',
    ],
    highlighted: true,
  },
  {
    name: 'Gold',
    price: '$3.99',
    originalPrice: '$5.99',
    badge: '🥇',
    tagline: 'Best value',
    features: [
      'Everything in Silver',
      '1-day courtesy before 8am',
      '50 chats · 1,000 messages each',
      '3+ years of history',
    ],
    highlighted: false,
  },
  {
    name: 'Diamond',
    price: '$9.99',
    originalPrice: '$14.99',
    badge: '💎',
    tagline: 'All access',
    features: [
      'Everything in Gold',
      '1-day courtesy before 10am',
      '100 chats · 2,000 messages each',
      'Lifetime status history',
      'First access to new features',
    ],
    highlighted: false,
  },
];
---

<section id="pricing" class="py-24 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Simple, <span class="gradient-text">lifetime</span> pricing
      </h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Pay once, keep forever. No subscriptions, no recurring charges.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {tiers.map(tier => (
        <div class:list={[
          'relative rounded-2xl p-6 flex flex-col',
          tier.highlighted
            ? 'bg-white dark:bg-gray-800 shadow-xl ring-2 ring-pin-500 dark:ring-pin-400 scale-[1.02]'
            : 'glass-card',
        ]}>
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-pin-500 text-white text-xs font-semibold rounded-full">
              Most Popular
            </div>
          )}

          <div class="mb-4">
            {tier.badge && <span class="text-2xl">{tier.badge}</span>}
            <h3 class="text-lg font-bold mt-1">{tier.name}</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">{tier.tagline}</p>
          </div>

          <div class="mb-6">
            <span class="text-3xl font-extrabold">{tier.price}</span>
            {tier.originalPrice && <span class="text-sm text-gray-400 dark:text-gray-500 ml-1 line-through">{tier.originalPrice}</span>}
            {tier.price !== '$0' && <span class="text-sm text-gray-500 dark:text-gray-400 ml-1">lifetime</span>}
          </div>

          <ul class="space-y-2.5 flex-1">
            {tier.features.map(feature => (
              <li class="flex items-start gap-2 text-sm">
                <svg class="w-4 h-4 mt-0.5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600 dark:text-gray-300">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
