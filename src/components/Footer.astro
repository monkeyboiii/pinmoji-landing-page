---
import AppStoreBadge from './AppStoreBadge.astro';
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Branding -->
      <div>
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/PinmojiApp.jpg" alt="Pinmoji" class="w-8 h-8 rounded-lg" />
          <span class="font-bold text-lg">Pinmoji</span>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">Express yourself on the map.</p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold text-sm mb-3">Links</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">Terms of Service</a></li>
          <li><a href="/support" class="text-sm text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">Support</a></li>
        </ul>
      </div>

      <!-- Download -->
      <div>
        <h3 class="font-semibold text-sm mb-3">Download</h3>
        <AppStoreBadge />
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800">
      <p class="text-xs text-gray-400 dark:text-gray-500">&copy; {new Date().getFullYear()} Pinmoji. All rights reserved.</p>
    </div>
  </div>
</footer>
