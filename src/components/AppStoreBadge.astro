---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a
  href="#"
  class:list={['inline-block transition-opacity hover:opacity-80', className]}
  aria-label="Download on the App Store"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 60" class="h-[52px] w-auto">
    <rect width="180" height="60" rx="10" fill="black" />
    <g fill="white">
      <!-- Apple logo approximation -->
      <path d="M36.5 18.8c-.7-2.1-2.3-3.3-4.2-3.3-1.1 0-2.2.4-3 .9-.6.3-1.1.5-1.3.5s-.8-.2-1.4-.6c-.9-.5-1.9-.9-3-.9h-.1c-2.4 0-4.5 1.8-5.3 4.5-.6 2-.3 5 1.1 8.2 1 2.3 2.8 5.1 5.3 5.1h.1c.7 0 1.3-.2 1.9-.5.5-.2 1-.4 1.5-.4.4 0 .9.2 1.4.4.6.3 1.3.5 2 .5 2.8-.1 4.5-3.5 5.3-5.6-1.5-.7-3-2.4-3-4.7 0-2 1.2-3.6 2.7-4.1zm-6.2-3.7c.8-1 1.3-2.3 1.2-3.6-1.2.1-2.6.8-3.4 1.9-.7.9-1.4 2.3-1.2 3.5 1.3.1 2.6-.7 3.4-1.8z"/>
      <!-- "Download on the" text -->
      <text x="50" y="22" font-family="Inter, -apple-system, sans-serif" font-size="9" font-weight="400" letter-spacing=".2">Download on the</text>
      <!-- "App Store" text -->
      <text x="50" y="40" font-family="Inter, -apple-system, sans-serif" font-size="18" font-weight="600">App Store</text>
    </g>
  </svg>
</a>
