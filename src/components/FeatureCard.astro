---
interface Props {
  emoji: string;
  title: string;
  description: string;
}

const { emoji, title, description } = Astro.props;
---

<div class="glass-card p-6 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
  <div class="text-4xl mb-4">{emoji}</div>
  <h3 class="text-lg font-semibold mb-2">{title}</h3>
  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{description}</p>
</div>
