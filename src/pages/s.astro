---
// Share bounce page: https://pinmoji.app/s?id=<status-id>&t=<title>&e=<emoji-shortcode>
//
// Universal Link target — when the Pinmoji iOS app is installed and the AASA
// match succeeds, iOS opens the app directly and this page never renders.
// If the app isn't installed (or AASA hasn't been re-fetched yet), we render
// OG meta for iMessage / social previews and offer install / open buttons.
//
// SSR'd so OG meta echoes the title and emoji from the URL query string the
// iOS share emits. Trust model: anything in `t` / `e` is attacker-controllable
// (same as any URL share). Sanitize before reflecting into HTML / URLs.

export const prerender = false;

import '../styles/global.css';

const params = Astro.url.searchParams;
const id = (params.get('id') ?? '').slice(0, 64);
// Emoji shortcode is used as a path segment. Restrict to the canonical
// shortcode charset (alphanumeric, underscore, '+', '-') and clamp length.
const emojiRaw = params.get('e') ?? '';
const emoji = emojiRaw.replace(/[^A-Za-z0-9_+\-]/g, '').slice(0, 64);
const titleRaw = (params.get('t') ?? '').trim();
const title = titleRaw ? titleRaw.slice(0, 140) : 'A Pinmoji status';
const description = "Open this Pinmoji status — see the emoji someone pinned to the map.";
const ogImage = emoji
  ? new URL(`/emojis/${emoji}.png`, Astro.url.origin).toString()
  : new URL('/og/share.jpg', Astro.site).toString();
const ogImageType = emoji ? 'image/png' : 'image/jpeg';
const appStoreUrl = 'https://apps.apple.com/us/app/pinmoji-emoji-map-pins/id6761286147';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="256" />
    <meta property="og:image:height" content="256" />
    <meta property="og:image:type" content={ogImageType} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- iMessage's LinkPresentation prefers apple-touch-icon for the compact
         card thumbnail. Pointing it at the per-share emoji PNG nudges iMessage
         away from the giant square hero card toward a small left thumbnail
         + title-to-the-right layout. -->
    <link rel="apple-touch-icon" href={ogImage} />

    <!-- Smart App Banner. Keep this ID in lockstep with the AppStoreBadge URL. -->
    <meta name="apple-itunes-app" content="app-id=6761286147" />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📍</text></svg>" />
  </head>
  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased">
    <main class="min-h-screen flex items-center justify-center px-4">
      <div class="max-w-md w-full text-center space-y-6">
        {emoji ? (
          <img
            src={ogImage}
            alt=""
            width="96"
            height="96"
            class="mx-auto"
          />
        ) : (
          <div class="text-6xl">📍</div>
        )}
        <h1 class="text-2xl font-bold">{title}</h1>
        <p class="text-gray-600 dark:text-gray-400">
          Open in the Pinmoji app to see where it was pinned.
        </p>
        <div class="flex flex-col gap-3 pt-2">
          <a
            id="open-app"
            href={appStoreUrl}
            class="inline-flex justify-center items-center px-6 py-3 rounded-full bg-black text-white font-semibold hover:opacity-90"
          >
            Open in Pinmoji
          </a>
          <a
            href="/"
            class="inline-flex justify-center items-center px-6 py-3 text-gray-700 dark:text-gray-300 underline"
          >
            Get the app
          </a>
        </div>
      </div>
    </main>

    <script is:inline>
      (function () {
        const params = new URLSearchParams(location.search);
        const id = params.get('id');
        if (!id) return;
        const appURL = 'pinmoji://map/status?id=' + encodeURIComponent(id);
        const button = document.getElementById('open-app');
        if (button) button.setAttribute('href', appURL);
      })();
    </script>
  </body>
</html>
