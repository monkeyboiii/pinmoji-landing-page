---
import BaseLayout from '../layouts/BaseLayout.astro';

const cards = [
  {
    emoji: '🚨',
    title: 'Report a Problem',
    description: 'Use the in-app report button on any status to flag inappropriate content. We review reports within 24 hours.',
  },
  {
    emoji: '🔑',
    title: 'Account Issues',
    description: 'For account deletion, recovery, or billing questions, email us and include the email address associated with your account.',
  },
  {
    emoji: '💬',
    title: 'General Questions',
    description: 'Check our FAQ first — most common questions are answered there. If you still need help, send us an email.',
  },
];
---

<BaseLayout title="Support — Pinmoji" description="Get help with Pinmoji. Contact our support team.">
  <section class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold mb-4">Need help?</h1>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          We're here to help. Reach out and we'll get back to you within 24 hours.
        </p>
        <a
          href="mailto:support@pinmoji.app"
          class="inline-flex items-center gap-2 px-6 py-3 bg-pin-500 hover:bg-pin-600 text-white font-semibold rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          support@pinmoji.app
        </a>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
        {cards.map(card => (
          <div class="glass-card p-6 text-center">
            <div class="text-3xl mb-3">{card.emoji}</div>
            <h3 class="font-semibold mb-2">{card.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">{card.description}</p>
          </div>
        ))}
      </div>

      <!-- FAQ link -->
      <div class="text-center">
        <p class="text-gray-500 dark:text-gray-400 text-sm">
          Looking for answers? Check our <a href="/#faq" class="text-pin-500 hover:text-pin-600 dark:text-pin-400 font-medium">FAQ</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
